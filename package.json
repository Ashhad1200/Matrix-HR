{
  "name": "matrixhr",
  "private": true,
  "scripts": {
    "predev": "pnpm --filter @matrixhr/shared build && pnpm --filter @matrixhr/database build && pnpm db:generate",
    "dev": "turbo dev --filter=@matrixhr/api --filter=@matrixhr/web",
    "dev:all": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @matrixhr/database generate",
    "db:migrate": "pnpm --filter @matrixhr/database migrate",
    "db:push": "pnpm --filter @matrixhr/database push",
    "db:seed": "pnpm --filter @matrixhr/database seed",
    "db:studio": "pnpm --filter @matrixhr/database studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
