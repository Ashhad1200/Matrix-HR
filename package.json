{
  "name": "matrixhr",
  "private": true,
  "scripts": {
    "setup": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1",
    "dev": "pnpm db:start && powershell -ExecutionPolicy Bypass -File scripts/wait-for-db.ps1 && powershell -ExecutionPolicy Bypass -File scripts/free-dev-ports.ps1 && turbo dev --filter=@matrixhr/api --filter=@matrixhr/web",
    "dev:all": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @matrixhr/database generate",
    "db:migrate": "pnpm --filter @matrixhr/database migrate",
    "db:start": "pnpm --filter @matrixhr/database exec prisma dev --detach",
    "db:push": "pnpm --filter @matrixhr/database push",
    "db:seed": "pnpm --filter @matrixhr/database seed",
    "db:studio": "pnpm --filter @matrixhr/database studio",
    "test:api": "pnpm --filter @matrixhr/database exec tsx ../../scripts/test-apis.ts"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
