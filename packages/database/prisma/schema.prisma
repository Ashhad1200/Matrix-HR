generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  HR_MANAGER
  MANAGER
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED
  RESIGNED
}

enum EmploymentType {
  PERMANENT
  CONTRACT
  PROBATION
  INTERN
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
  HOLIDAY
}

enum AttendanceSource {
  WEB
  MOBILE
  BIOMETRIC
  MANUAL
  WHATSAPP
}

enum OnboardingTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum PayrollRunStatus {
  DRAFT
  REVIEW
  APPROVED
  PROCESSED
  LOCKED
}

enum JobApplicationStatus {
  APPLIED
  SCREENING
  SHORTLISTED
  INTERVIEW
  ASSESSMENT
  OFFER
  HIRED
  REJECTED
}

enum ReviewCycleStatus {
  DRAFT
  ACTIVE
  COMPLETED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  WHATSAPP
  SMS
  PUSH
}

// ─── Auth & Tenancy ──────────────────────────────────────────────────────────

model Tenant {
  id        String       @id @default(cuid())
  name      String
  subdomain String       @unique
  plan      String       @default("starter")
  status    TenantStatus @default(ACTIVE)
  timezone  String       @default("Asia/Karachi")
  currency  String       @default("PKR")
  locale    String       @default("en")
  logoUrl   String?
  primaryColor String?   @default("#2563eb")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users              User[]
  employees          Employee[]
  departments        Department[]
  designations       Designation[]
  leavePolicies      LeavePolicy[]
  leaveRequests      LeaveRequest[]
  holidays           Holiday[]
  shifts             Shift[]
  attendanceLogs     AttendanceLog[]
  officeLocations    OfficeLocation[]
  onboardingTemplates OnboardingTemplate[]
  payrollRuns        PayrollRun[]
  salaryStructures   SalaryStructure[]
  jobPostings        JobPosting[]
  reviewCycles       ReviewCycle[]
  courses            Course[]
  auditLogs          AuditLog[]
  notifications      Notification[]
  whatsappMessages   WhatsAppMessage[]
  customFieldDefs    CustomFieldDefinition[]
  workflowDefs       WorkflowDefinition[]
  workflowInstances  WorkflowInstance[]
  webhooks           Webhook[]
  tenantIntegrations TenantIntegration[]
  enpsSurveys        EnpsSurvey[]
  formulaDefinitions FormulaDefinition[]
  apiKeys            ApiKey[]
  preboardingInvites PreboardingInvite[]
  esignRequests      EsignRequest[]
  reportDefinitions  ReportDefinition[]
  extensionAccess    ExtensionPanelAccess[]
  peerReviews360     PeerReview360[]
  oneOnOnes          OneOnOne[]
  projects           Project[]
  timeEntries        TimeEntry[]
  ssoConfig          SsoConfig?
}

model User {
  id           String     @id @default(cuid())
  tenantId     String
  employeeId   String?    @unique
  email        String
  passwordHash String
  role         UserRole   @default(EMPLOYEE)
  status       UserStatus @default(ACTIVE)
  twoFaEnabled Boolean    @default(false)
  twoFaSecret  String?
  failedAttempts Int      @default(0)
  lockedUntil  DateTime?
  emailVerified Boolean   @default(false)
  emailVerifyToken String?
  passwordResetToken String?
  passwordResetExpires DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee? @relation(fields: [employeeId], references: [id])
  sessions Session[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Session {
  id               String   @id @default(cuid())
  userId           String
  refreshTokenHash String
  deviceInfo       String?
  ipAddress        String?
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Employee Database (HRIS) ────────────────────────────────────────────────

model Department {
  id              String  @id @default(cuid())
  tenantId        String
  name            String
  parentId        String?
  headEmployeeId  String?
  costCenter      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent     Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children   Department[] @relation("DeptHierarchy")
  employees  Employee[]
  designations Designation[]

  @@index([tenantId])
}

model Designation {
  id           String @id @default(cuid())
  tenantId     String
  name         String
  grade        String?
  departmentId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id])
  employees  Employee[]

  @@index([tenantId])
}

model Employee {
  id               String         @id @default(cuid())
  tenantId         String
  employeeCode     String
  // Personal
  firstName        String
  lastName         String
  fatherName       String?
  cnic             String?
  gender           String?
  dateOfBirth      DateTime?
  maritalStatus    String?
  nationality      String?        @default("Pakistani")
  bloodGroup       String?
  phone            String?
  email            String?
  currentAddress   String?
  permanentAddress String?
  emergencyContact String?
  emergencyPhone   String?
  photoUrl         String?
  // Employment
  designationId    String?
  departmentId     String?
  managerId        String?
  employmentType   EmploymentType @default(PERMANENT)
  dateOfJoining    DateTime?
  probationEndDate DateTime?
  confirmationDate DateTime?
  workLocation     String?
  status           EmployeeStatus @default(ACTIVE)
  // Compensation (stored for payroll)
  baseSalary       Decimal?       @db.Decimal(12, 2)
  bankAccount      String?
  iban             String?
  ntn              String?
  // Custom fields
  customFields     Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  designation  Designation?  @relation(fields: [designationId], references: [id])
  department   Department?   @relation(fields: [departmentId], references: [id])
  manager      Employee?     @relation("EmployeeManager", fields: [managerId], references: [id])
  directReports Employee[]   @relation("EmployeeManager")
  user         User?
  documents    EmployeeDocument[]
  family       EmployeeFamily[]
  skills       EmployeeSkill[]
  history      EmploymentHistory[]
  leaveBalances LeaveBalance[]
  leaveRequests LeaveRequest[] @relation("LeaveEmployee")
  approvedLeaves LeaveRequest[] @relation("LeaveApprover")
  attendanceLogs AttendanceLog[]
  onboardingProgress OnboardingProgress[]
  payrollItems PayrollItem[]
  goals        Goal[]
  courseEnrollments CourseEnrollment[]
  jobApplications JobApplication[]
  oneOnOnesAsManager  OneOnOne[] @relation("OneOnOneManager")
  oneOnOnesAsEmployee OneOnOne[] @relation("OneOnOneEmployee")
  timeEntries  TimeEntry[]

  @@unique([tenantId, employeeCode])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, departmentId])
}

model EmployeeDocument {
  id         String    @id @default(cuid())
  tenantId   String
  employeeId String
  type       String
  name       String
  fileUrl    String
  issueDate  DateTime?
  expiryDate DateTime?
  verified   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, employeeId])
}

model EmployeeFamily {
  id         String   @id @default(cuid())
  employeeId String
  relation   String
  name       String
  dateOfBirth DateTime?
  isDependent Boolean @default(false)
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model EmployeeSkill {
  id          String  @id @default(cuid())
  employeeId  String
  skill       String
  proficiency String?
  certified   Boolean @default(false)
  createdAt   DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model EmploymentHistory {
  id            String   @id @default(cuid())
  employeeId    String
  event         String
  effectiveFrom DateTime
  effectiveTo   DateTime?
  salaryBefore  Decimal? @db.Decimal(12, 2)
  salaryAfter   Decimal? @db.Decimal(12, 2)
  notes         String?
  createdAt     DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ─── Leave Management ────────────────────────────────────────────────────────

model LeavePolicy {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  code            String
  daysPerYear     Decimal  @db.Decimal(5, 1)
  accrualType     String   @default("yearly") // yearly, monthly
  carryForwardMax Decimal? @db.Decimal(5, 1)
  allowHalfDay    Boolean  @default(true)
  allowNegative   Boolean  @default(false)
  genderRestriction String?
  eligibilityMonths Int    @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  balances  LeaveBalance[]
  requests  LeaveRequest[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model LeaveBalance {
  id         String  @id @default(cuid())
  tenantId   String
  employeeId String
  policyId   String
  year       Int
  entitled   Decimal @db.Decimal(5, 1)
  used       Decimal @db.Decimal(5, 1) @default(0)
  pending    Decimal @db.Decimal(5, 1) @default(0)
  carried    Decimal @db.Decimal(5, 1) @default(0)

  employee Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  policy   LeavePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([employeeId, policyId, year])
  @@index([tenantId])
}

model LeaveRequest {
  id           String             @id @default(cuid())
  tenantId     String
  employeeId   String
  policyId     String
  startDate    DateTime
  endDate      DateTime
  isHalfDay    Boolean            @default(false)
  halfDayPeriod String?           // morning, afternoon
  days         Decimal            @db.Decimal(5, 1)
  reason       String?
  attachmentUrl String?
  status       LeaveRequestStatus @default(PENDING)
  approverId   String?
  approvedAt   DateTime?
  rejectionReason String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee    @relation("LeaveEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  policy   LeavePolicy @relation(fields: [policyId], references: [id])
  approver Employee?   @relation("LeaveApprover", fields: [approverId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, employeeId])
}

model Holiday {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  date      DateTime @db.Date
  isOptional Boolean @default(false)
  country   String   @default("PK")
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, date])
}

// ─── Attendance ──────────────────────────────────────────────────────────────

model Shift {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  type        String  @default("fixed") // fixed, flexible, rotational
  startTime   String? // HH:mm
  endTime     String?
  graceMinutes Int    @default(10)
  workingHours Decimal @db.Decimal(4, 1) @default(8)
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attendanceLogs AttendanceLog[]

  @@index([tenantId])
}

model OfficeLocation {
  id        String  @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  latitude  Decimal @db.Decimal(10, 7)
  longitude Decimal @db.Decimal(10, 7)
  radiusMeters Int  @default(100)
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model AttendanceLog {
  id         String           @id @default(cuid())
  tenantId   String
  employeeId String
  shiftId    String?
  date       DateTime         @db.Date
  clockIn    DateTime?
  clockOut   DateTime?
  hours      Decimal?         @db.Decimal(4, 2)
  status     AttendanceStatus @default(PRESENT)
  source     AttendanceSource @default(WEB)
  latitude   Decimal?         @db.Decimal(10, 7)
  longitude  Decimal?         @db.Decimal(10, 7)
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift    Shift?   @relation(fields: [shiftId], references: [id])
  regularization RegularizationRequest?

  @@unique([tenantId, employeeId, date])
  @@index([tenantId, date])
}

model RegularizationRequest {
  id              String   @id @default(cuid())
  tenantId        String
  attendanceLogId String   @unique
  reason          String
  requestedClockIn DateTime?
  requestedClockOut DateTime?
  status          String   @default("pending") // pending, approved, rejected
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())

  attendanceLog AttendanceLog @relation(fields: [attendanceLogId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ─── Onboarding ──────────────────────────────────────────────────────────────

model OnboardingTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  role        String?
  department  String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tasks  OnboardingTask[]
  progress OnboardingProgress[]

  @@index([tenantId])
}

model OnboardingTask {
  id         String @id @default(cuid())
  templateId String
  title      String
  description String?
  phase      String @default("day1") // pre_joining, day1, week1, month1, month3
  order      Int    @default(0)
  assignee   String @default("employee") // employee, hr, manager, it
  isRequired Boolean @default(true)
  createdAt  DateTime @default(now())

  template OnboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  progress OnboardingTaskProgress[]
}

model OnboardingProgress {
  id         String   @id @default(cuid())
  tenantId   String
  employeeId String
  templateId String
  startedAt  DateTime @default(now())
  completedAt DateTime?
  status     String   @default("in_progress")

  employee Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  template OnboardingTemplate @relation(fields: [templateId], references: [id])
  tasks    OnboardingTaskProgress[]

  @@index([tenantId, employeeId])
}

model OnboardingTaskProgress {
  id         String               @id @default(cuid())
  progressId String
  taskId     String
  status     OnboardingTaskStatus @default(PENDING)
  completedAt DateTime?
  notes      String?

  progress OnboardingProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)
  task     OnboardingTask     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([progressId, taskId])
}

// ─── Payroll ─────────────────────────────────────────────────────────────────

model SalaryStructure {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  components Json    // [{name, type, amount, formula}]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model PayrollRun {
  id        String           @id @default(cuid())
  tenantId  String
  period    String           // 2026-01
  status    PayrollRunStatus @default(DRAFT)
  processedAt DateTime?
  approvedBy  String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  PayrollItem[]

  @@unique([tenantId, period])
  @@index([tenantId])
}

model PayrollItem {
  id            String  @id @default(cuid())
  payrollRunId  String
  employeeId    String
  grossSalary   Decimal @db.Decimal(12, 2)
  deductions    Decimal @db.Decimal(12, 2)
  netSalary     Decimal @db.Decimal(12, 2)
  taxAmount     Decimal @db.Decimal(12, 2) @default(0)
  eobiAmount    Decimal @db.Decimal(12, 2) @default(0)
  pfAmount      Decimal @db.Decimal(12, 2) @default(0)
  breakdown     Json?
  payslipUrl    String?
  disbursed     Boolean @default(false)

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id])

  @@index([payrollRunId])
}

// ─── Recruitment / ATS ───────────────────────────────────────────────────────

model JobPosting {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  department  String?
  description String?
  requirements String?
  status      String   @default("open") // open, closed, draft
  postedAt    DateTime @default(now())
  closedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  applications JobApplication[]

  @@index([tenantId, status])
}

model JobApplication {
  id         String               @id @default(cuid())
  tenantId   String
  jobId      String
  firstName  String
  lastName   String
  email      String
  phone      String?
  resumeUrl  String?
  source     String?
  status     JobApplicationStatus @default(APPLIED)
  score      Int?
  notes      String?
  employeeId String?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  job      JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)
  employee Employee?  @relation(fields: [employeeId], references: [id])

  @@index([tenantId, jobId, status])
}

// ─── Performance Management ──────────────────────────────────────────────────

model ReviewCycle {
  id        String            @id @default(cuid())
  tenantId  String
  name      String
  type      String            @default("quarterly")
  startDate DateTime
  endDate   DateTime
  status    ReviewCycleStatus @default(DRAFT)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  goals   Goal[]
  reviews PerformanceReview[]

  @@index([tenantId])
}

model Goal {
  id          String  @id @default(cuid())
  tenantId    String
  employeeId  String
  cycleId     String?
  title       String
  description String?
  weight      Int     @default(1)
  progress    Int     @default(0)
  status      String  @default("active")
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  cycle    ReviewCycle? @relation(fields: [cycleId], references: [id])

  @@index([tenantId, employeeId])
}

model PerformanceReview {
  id           String  @id @default(cuid())
  tenantId     String
  cycleId      String
  employeeId   String
  reviewerId   String
  selfRating   Int?
  managerRating Int?
  feedback     String?
  status       String  @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cycle ReviewCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@index([tenantId, cycleId])
}

// ─── LMS ─────────────────────────────────────────────────────────────────────

model Course {
  id          String       @id @default(cuid())
  tenantId    String
  title       String
  description String?
  content     Json?
  duration    Int?
  status      CourseStatus @default(DRAFT)
  isMandatory Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enrollments CourseEnrollment[]

  @@index([tenantId])
}

model CourseEnrollment {
  id          String    @id @default(cuid())
  courseId    String
  employeeId  String
  progress    Int       @default(0)
  score       Int?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([courseId, employeeId])
}

// ─── Cross-Cutting ───────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String
  entity     String
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, entity, createdAt])
}

model Notification {
  id        String              @id @default(cuid())
  tenantId  String
  userId    String
  title     String
  body      String
  channel   NotificationChannel @default(IN_APP)
  read      Boolean             @default(false)
  metadata  Json?
  createdAt DateTime            @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, read])
}

model WhatsAppMessage {
  id          String   @id @default(cuid())
  tenantId    String
  recipientPhone String
  templateName String?
  body        String
  status      String   @default("sent") // sent, delivered, read, failed
  direction   String   @default("outbound")
  metadata    Json?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

// ─── Custom Fields & Workflows (Phase 2) ─────────────────────────────────────

model CustomFieldDefinition {
  id         String   @id @default(cuid())
  tenantId   String
  entity     String   @default("Employee")
  key        String
  label      String
  fieldType  String   // text, number, date, dropdown, boolean
  options    Json?
  required   Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, entity, key])
  @@index([tenantId])
}

model WorkflowDefinition {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  trigger     String   // employee.salary_change, leave.request, etc.
  steps       Json     // [{role, order, action}]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instances WorkflowInstance[]

  @@index([tenantId])
}

model WorkflowInstance {
  id           String   @id @default(cuid())
  tenantId     String
  definitionId String
  entityType   String
  entityId     String
  currentStep  Int      @default(0)
  status       String   @default("pending") // pending, approved, rejected
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  definition WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

// ─── Integrations & Webhooks (Phase 5) ───────────────────────────────────────

model Webhook {
  id        String   @id @default(cuid())
  tenantId  String
  url       String
  events    String[] // employee.created, employee.terminated, leave.approved
  secret    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([tenantId])
}

model WebhookDelivery {
  id         String   @id @default(cuid())
  webhookId  String
  event      String
  payload    Json
  status     String   @default("pending") // pending, delivered, failed
  response   String?
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, status])
}

model TenantIntegration {
  id           String   @id @default(cuid())
  tenantId     String
  provider     String   // slack, okta, deel
  status       String   @default("disconnected")
  accessToken  String?
  refreshToken String?
  config       Json?
  installedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
  @@index([tenantId])
}

model FormulaDefinition {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  entity    String
  expression String  // e.g. "dateOfJoining + 90 days"
  targetField String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model ApiKey {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  keyHash   String
  prefix    String
  lastUsed  DateTime?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ─── Talent Acquisition Extensions (Phase 3) ───────────────────────────────

model PreboardingInvite {
  id          String   @id @default(cuid())
  tenantId    String
  applicationId String?
  email       String
  token       String   @unique
  expiresAt   DateTime
  status      String   @default("pending")
  documents   Json?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, token])
}

model EsignRequest {
  id         String   @id @default(cuid())
  tenantId   String
  entityType String
  entityId   String
  signerEmail String
  documentUrl String
  status     String   @default("pending") // pending, signed, declined
  signedAt   DateTime?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

// ─── Experience (Phase 6) ───────────────────────────────────────────────────

model EnpsSurvey {
  id        String   @id @default(cuid())
  tenantId  String
  title     String
  question  String   @default("How likely are you to recommend this company?")
  status    String   @default("draft")
  sentAt    DateTime?
  closesAt  DateTime?
  createdAt DateTime @default(now())

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  responses EnpsResponse[]

  @@index([tenantId])
}

model EnpsResponse {
  id        String   @id @default(cuid())
  surveyId  String
  score     Int      // 0-10
  comment   String?
  createdAt DateTime @default(now())

  survey EnpsSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@index([surveyId])
}

model PeerReview360 {
  id           String   @id @default(cuid())
  tenantId     String
  cycleId      String
  employeeId   String
  reviewerId   String
  relationship String   @default("peer") // peer, direct_report, skip_level
  rating       Int?
  feedback     String?
  isAnonymous  Boolean  @default(true)
  status       String   @default("pending")
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, cycleId])
}

// ─── Enterprise (Phase 7) ────────────────────────────────────────────────────

model ReportDefinition {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  config    Json     // columns, filters, groupBy
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model ExtensionPanelAccess {
  id        String   @id @default(cuid())
  tenantId  String
  panel     String   // recruitment, it_assets, compliance
  userId    String?
  role      String?
  readOnly  Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, panel])
}

// ─── Manager Hub: 1-on-1s ────────────────────────────────────────────────────

model OneOnOne {
  id          String    @id @default(cuid())
  tenantId    String
  managerId   String
  employeeId  String
  scheduledAt DateTime
  status      String    @default("scheduled") // scheduled, completed, cancelled
  talkingPoints Json?   // [{text, done}]
  notes       String?
  privateNotes String?  // manager-only
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  manager  Employee @relation("OneOnOneManager", fields: [managerId], references: [id], onDelete: Cascade)
  employee Employee @relation("OneOnOneEmployee", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, managerId])
  @@index([tenantId, employeeId])
}

// ─── Time Tracking: Projects & Timesheets ────────────────────────────────────

model Project {
  id        String   @id @default(cuid())
  tenantId  String
  key       String   // e.g. MTX, ACME-WEB
  name      String
  status    String   @default("active") // active, archived
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entries TimeEntry[]

  @@unique([tenantId, key])
  @@index([tenantId])
}

model TimeEntry {
  id         String   @id @default(cuid())
  tenantId   String
  employeeId String
  projectId  String?
  date       DateTime
  hours      Decimal  @db.Decimal(5, 2)
  note       String?
  status     String   @default("draft") // draft, submitted, approved, rejected
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  project  Project? @relation(fields: [projectId], references: [id])

  @@index([tenantId, employeeId, date])
  @@index([tenantId, status])
}

// ─── Enterprise SSO ──────────────────────────────────────────────────────────

model SsoConfig {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  provider     String   @default("saml") // saml, oidc
  enabled      Boolean  @default(false)
  entryPoint   String?  // IdP SSO URL
  issuer       String?
  certificate  String?  // IdP x509 cert (PEM)
  metadataUrl  String?
  domains      Json?    // allowed email domains
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}
